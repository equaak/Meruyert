# ─────────────────────────────────────────────────────────────────────
# Шаблон переменных окружения для Kaspi Dashboard.
#
# Этот файл коммитится в git как ШАБЛОН. Реальные значения положите в
# .env.local (он в .gitignore — не уйдёт в репо). Эти же значения
# нужно продублировать в Vercel → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────

# ─── Kaspi Marketplace API ──────────────────────────────────────────
# Persistent X-Auth-Token из Kaspi Merchant Cabinet → Настройки → API.
# X-Merchant-Uid обязателен — без него API возвращает пустые результаты
# (подтверждено поддержкой Kaspi Pay).
KASPI_API_BASE=https://kaspi.kz/shop/api/v2
KASPI_TOKEN=
KASPI_MERCHANT_ID=
# Название магазина — отображается в шапке и левом меню. Можно русским.
KASPI_MERCHANT_NAME=

# ─── (Опционально) Отключить Basic Auth ─────────────────────────────
# Если задать PUBLIC_DEMO любым значением (даже пустым) — middleware
# пропустит всех. Использовать только для временных демо.
PUBLIC_DEMO=1
